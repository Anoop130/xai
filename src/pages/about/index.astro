---
// about page: program description, PI info, location, and contact
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import viniPhoto from '../../assets/pi/chaudhary.jpg';
import charanPhoto from '../../assets/pi/gudla.jpg';
import andyPhoto from '../../assets/pi/perkins.jpg';

const principalInvestigators = [
  {
    name: 'Dr. Vini Chaudhary',
    email: 'vchaudhary@cse.msstate.edu',
    dept: 'Mississippi State University',
    photo: viniPhoto,
  },
  {
    name: 'Dr. Charan Gudla',
    email: 'gudla@cse.msstate.edu',
    dept: 'Mississippi State University',
    photo: charanPhoto,
  },
  {
    name: 'Dr. Andy Perkins',
    email: 'perkins@cse.msstate.edu',
    dept: 'Mississippi State University',
    photo: andyPhoto,
  },
];
---

<Base
  title="About"
  description="About the NSF ExLENT XAI Initiative: mission, principal investigators, program location, and contact."
>
  <div class="max-w-5xl">
    <h1 class="text-3xl font-bold text-maroon-900 mb-8">About</h1>

    <!-- program overview -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-maroon-800 mb-3">Program Overview</h2>
      <p class="text-gray-700 leading-relaxed mb-3">
        The NSF ExLENT XAI Initiative is a National Science Foundation funded experiential learning
        program at Mississippi State University designed for early career undergraduate students
        seeking foundational training and hands on experience in Artificial Intelligence and
        Machine Learning.
      </p>
      <p class="text-gray-700 leading-relaxed">
        Students complete 16 weeks of hybrid coursework spanning Python, supervised and unsupervised
        learning, deep learning, responsible AI, and model deployment, followed by a guaranteed paid
        industry internship in healthcare analytics or cybersecurity.
      </p>
    </section>

    <!-- course details -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-maroon-800 mb-4">Course Information</h2>
      <dl class="space-y-2.5 text-sm">
        {[
          ['Course', 'Introduction to Machine Learning'],
          ['Modality', 'Hybrid (In-Person + Online)'],
          ['Location', 'Butler Hall 102, 665 George Perry Street, Mississippi State University'],
          ['Schedule', 'Fridays 3:30 PM - 5:00 PM (online) | Saturdays 12:00 PM - 2:00 PM (in-person)'],
          ['Instructor', 'Dr. Nisha Pillai'],
          ['Email', 'pillai@cse.msstate.edu'],
          ['Prerequisites', 'Python programming experience'],
          ['Software', 'Python, Scikit-learn, TensorFlow, PyTorch, and related deep learning libraries'],
        ].map(([label, value]) => (
          <div class="flex gap-3">
            <dt class="font-semibold text-gray-700 w-28 shrink-0">{label}</dt>
            <dd class="text-gray-600">{value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- principal investigators -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-maroon-800 mb-4">Principal Investigators</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {principalInvestigators.map((pi) => (
          <div class="rounded-2xl border border-maroon-200 bg-maroon-50 overflow-hidden">
            <Image
              src={pi.photo}
              alt={`${pi.name} headshot`}
              width={400}
              height={560}
              class="h-72 w-full object-cover object-top"
            />
            <div class="p-5">
              <p class="font-semibold text-maroon-900 text-lg">{pi.name}</p>
              <p class="text-sm text-gray-600 mt-1 leading-relaxed">{pi.dept}</p>
              <p class="text-sm text-maroon-700 mt-3">{pi.email}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- funding and partners -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-maroon-800 mb-4">Funding and Partners</h2>
      <div class="space-y-3">
        <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 border border-gray-200">
          <!-- NSF logo placeholder -->
          <div class="w-14 h-14 rounded-lg bg-[#00558C] flex items-center justify-center text-white font-bold text-base shrink-0">
            NSF
          </div>
          <div>
            <p class="font-semibold text-gray-800">National Science Foundation</p>
            <p class="text-sm text-gray-600 mt-1">
              Funded through NSF ExLENT (Experiential Learning for Emerging and Novel Technologies),
              supporting emerging technology education for early career students.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 border border-gray-200">
          <!-- MSU placeholder -->
          <div class="w-14 h-14 rounded-lg bg-maroon-900 flex items-center justify-center text-white font-bold text-sm shrink-0 text-center leading-tight p-1">
            MSU
          </div>
          <div>
            <p class="font-semibold text-gray-800">Mississippi State University</p>
            <p class="text-sm text-gray-600 mt-1">
              Bagley College of Engineering.
              Butler Hall, 665 George Perry Street, Mississippi State, MS 39762.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- contact -->
    <section>
      <h2 class="text-xl font-semibold text-maroon-800 mb-3">Contact</h2>
      <p class="text-gray-700 mb-3">
        For program inquiries, reach out to the principal investigators or the course instructor.
      </p>
      <ul class="space-y-2 text-sm">
        {[
          ['Dr. Vini Chaudhary', 'vchaudhary@cse.msstate.edu'],
          ['Dr. Charan Gudla', 'gudla@cse.msstate.edu'],
          ['Dr. Andy Perkins', 'perkins@cse.msstate.edu'],
          ['Dr. Nisha Pillai', 'pillai@cse.msstate.edu'],
        ].map(([name, email]) => (
          <li>
            <span class="font-medium text-gray-800">{name}:</span>{' '}
            <a href={`mailto:${email}`} class="text-maroon-700 hover:underline">{email}</a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>
