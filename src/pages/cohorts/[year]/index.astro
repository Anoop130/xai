---
// cohort year page: student card grid for a single cohort year
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import { withBase } from '../../../lib/urls';

// generate one route per cohort entry
export async function getStaticPaths() {
  const cohorts = await getCollection('cohorts');
  const students = await getCollection('students');

  return cohorts.map((cohort) => ({
    params: { year: String(cohort.data.year) },
    props: {
      cohort,
      students: students.filter((s) => s.data.cohortYear === cohort.data.year),
    },
  }));
}

const { cohort, students } = Astro.props;
---

<Base
  title={`Cohort ${cohort.data.year}`}
  description={cohort.data.description}
>
  <!-- breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
    <a href={withBase('cohorts/')} class="hover:text-maroon-700">Cohorts</a>
    <span class="mx-2" aria-hidden="true">/</span>
    <span class="text-gray-900">{cohort.data.year}</span>
  </nav>

  <h1 class="text-3xl font-bold text-maroon-900 mb-2">Cohort {cohort.data.year}</h1>
  <p class="text-gray-600 mb-10">{cohort.data.description}</p>

  <!-- student cards grid -->
  {
    students.length === 0 ? (
      <p class="text-gray-500">no students listed for this cohort yet</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {students.map((student) => (
          <div
            class="flex flex-col items-center text-center rounded-2xl border border-gray-200 p-6 bg-white min-h-64"
          >
            {/* profile photo or svg avatar placeholder */}
            {student.data.photo ? (
              <Image
                src={student.data.photo}
                alt={`${student.data.name} photo`}
                width={88}
                height={88}
                class="rounded-full object-cover mb-4 ring-2 ring-maroon-100"
              />
            ) : (
              <div class="w-[88px] h-[88px] rounded-full overflow-hidden mb-4 ring-2 ring-maroon-200">
                <svg viewBox="0 0 72 72" class="w-full h-full" aria-hidden="true">
                  <rect width="72" height="72" fill="#fce7ea"/>
                  <ellipse cx="36" cy="28" rx="12" ry="13" fill="#9a1728"/>
                  <ellipse cx="36" cy="62" rx="23" ry="17" fill="#9a1728"/>
                </svg>
              </div>
            )}
            <p class="text-base font-semibold text-gray-900 mb-1 leading-tight">
              {student.data.name}
            </p>
            {student.data.school && (
              <p class="text-sm text-gray-500 mb-2">{student.data.school}</p>
            )}
            {student.data.major && (
              <span class="text-xs bg-purple-100 text-purple-700 px-2.5 py-1 rounded-full">
                {student.data.major}
              </span>
            )}
            <p class="text-sm text-gray-500 mt-4 leading-relaxed">{student.data.bio}</p>
          </div>
        ))}
      </div>
    )
  }
</Base>
