---
// student profile page with bio, school, major, internship, capstone, and links
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import { withBase } from '../../../lib/urls';

// generate one route per student entry, nested under the cohort year
export async function getStaticPaths() {
  const students = await getCollection('students');
  return students.map((student) => ({
    params: {
      year: String(student.data.cohortYear),
      student: student.id,
    },
    props: { student },
  }));
}

const { student } = Astro.props;
const { Content } = await render(student);
const { name, bio, cohortYear, photo, school, major, internship, capstone, links } = student.data;
---

<Base title={name} description={bio}>
  <div class="max-w-2xl">
    <!-- breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href={withBase('cohorts/')} class="hover:text-maroon-700">Cohorts</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <a href={withBase(`cohorts/${cohortYear}/`)} class="hover:text-maroon-700">{cohortYear}</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-gray-900">{name}</span>
    </nav>

    <!-- profile header -->
    <div class="flex items-start gap-6 mb-8">
      {
        photo ? (
          <Image
            src={photo}
            alt={`${name} profile photo`}
            width={96}
            height={96}
            class="rounded-full object-cover flex-shrink-0 ring-2 ring-maroon-200"
          />
        ) : (
          <div class="w-24 h-24 rounded-full overflow-hidden flex-shrink-0 ring-2 ring-maroon-200">
            <svg viewBox="0 0 96 96" class="w-full h-full" aria-hidden="true">
              <rect width="96" height="96" fill="#fce7ea"/>
              <ellipse cx="48" cy="37" rx="16" ry="18" fill="#9a1728"/>
              <ellipse cx="48" cy="82" rx="30" ry="22" fill="#9a1728"/>
            </svg>
          </div>
        )
      }
      <div>
        <h1 class="text-3xl font-bold text-gray-900 mb-1">{name}</h1>
        <p class="text-gray-500 text-sm mb-2">Cohort {cohortYear}</p>
        {school && (
          <p class="text-sm text-gray-600">{school}</p>
        )}
        {major && (
          <span class="inline-block mt-1 text-xs bg-purple-100 text-purple-700 px-2.5 py-0.5 rounded-full">
            {major}
          </span>
        )}
      </div>
    </div>

    <!-- rendered Markdown bio body -->
    <div class="prose prose-gray max-w-none mb-8">
      <Content />
    </div>

    <!-- internship card shown when available -->
    {
      internship && (
        <section class="mb-6 p-4 bg-maroon-50 rounded-lg border border-maroon-200">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-maroon-700 mb-2">
            Internship
          </h2>
          <p class="text-gray-800 font-medium">
            {internship.role} at {internship.org}
          </p>
          <p class="text-sm text-gray-600">{internship.year}</p>
        </section>
      )
    }

    <!-- capstone card shown when available -->
    {
      capstone && (
        <section class="mb-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-gray-600 mb-2">
            Capstone
          </h2>
          <p class="text-gray-800 font-medium">{capstone.title}</p>
          <p class="text-sm text-gray-600 mt-1">{capstone.summary}</p>
          {capstone.repoUrl && (
            <a
              href={capstone.repoUrl}
              class="text-maroon-700 hover:underline text-sm mt-2 inline-block"
              target="_blank"
              rel="noopener noreferrer"
            >
              View repository
            </a>
          )}
        </section>
      )
    }

    <!-- external profile links -->
    {
      links && (
        <div class="flex gap-4">
          {links.github && (
            <a
              href={links.github}
              class="text-sm text-gray-600 hover:text-maroon-700"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          )}
          {links.linkedin && (
            <a
              href={links.linkedin}
              class="text-sm text-gray-600 hover:text-maroon-700"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          )}
        </div>
      )
    }
  </div>
</Base>
