---
// cohorts index: year selector with student cards via CohortYearSwitcher
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CohortYearSwitcher from '../../components/islands/CohortYearSwitcher.tsx';

// fetch cohorts and all students
const cohorts = await getCollection('cohorts');
const students = await getCollection('students');

// build serializable cohort list sorted newest first
const cohortProps = cohorts
  .sort((a, b) => b.data.year - a.data.year)
  .map((c) => ({
    year: c.data.year,
    description: c.data.description,
    startDate: c.data.startDate.toLocaleDateString('en-US', {
      month: 'long',
      year: 'numeric',
    }),
    endDate: c.data.endDate?.toLocaleDateString('en-US', {
      month: 'long',
      year: 'numeric',
    }),
    studentCount: students.filter((s) => s.data.cohortYear === c.data.year).length,
  }));

// serialize student data for the island (no image objects, only serializable fields)
const studentProps = students.map((s) => ({
  id: s.id,
  name: s.data.name,
  school: s.data.school,
  major: s.data.major,
  cohortYear: s.data.cohortYear,
}));

const base = import.meta.env.BASE_URL;
---

<Base
  title="Cohorts"
  description="Program cohorts by year. Each cohort participates in weekly AI/ML sessions."
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-maroon-900 mb-2">Cohorts</h1>
    <p class="text-gray-600">
      Each year a new cohort joins the NSF ExLENT XAI program for hybrid sessions in AI and machine
      learning.
    </p>
  </div>

  <!-- CohortYearSwitcher is a React island loaded on the client -->
  <CohortYearSwitcher cohorts={cohortProps} students={studentProps} base={base} client:load />
</Base>
