---
// homepage: full-width hero, program info, cohort cards, and recent sessions
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/urls';

// fetch recent sessions sorted newest first
const allSessions = await getCollection('sessions');
const recentSessions = allSessions
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// fetch the current cohort (highest year number)
const cohorts = await getCollection('cohorts');
const currentCohort = cohorts.sort((a, b) => b.data.year - a.data.year)[0];

// fetch students for the current cohort
const allStudents = await getCollection('students');
const currentStudents = currentCohort
  ? allStudents.filter((s) => s.data.cohortYear === currentCohort.data.year)
  : [];

// map topic value to display label
const TOPIC_LABELS: Record<string, string> = {
  ai: 'AI',
  ml: 'ML',
  'data-science': 'Data Science',
  tooling: 'Tooling',
  guest: 'Guest',
};

// course schedule derived from syllabus
const courseSchedule = [
  { weeks: '1-2',   topic: 'Foundations: AI/ML overview, Python, NumPy, Pandas, and AI ethics' },
  { weeks: '3-4',   topic: 'Data Processing: feature engineering, encoding, scaling, handling missing data' },
  { weeks: '5-6',   topic: 'Supervised Learning: regression, decision trees, SVM, model evaluation' },
  { weeks: '7',     topic: 'Unsupervised Learning: clustering, PCA, Gaussian Mixture Models' },
  { weeks: '8-10',  topic: 'Deep Learning: neural networks, Keras/TensorFlow, CNNs' },
  { weeks: '11',    topic: 'Responsible AI: fairness, bias, privacy, federated learning' },
  { weeks: '12-13', topic: 'Deployment: Docker, FastAPI, MLflow, transfer learning' },
  { weeks: '14-16', topic: 'Capstone Project: applied project with final presentation and evaluation' },
];

// semester 1 features list
const sem1Features = [
  'Python for AI/ML',
  'Supervised and unsupervised learning',
  'Deep learning fundamentals',
  'Ethical and privacy preserving AI',
  'Applied project learning',
];

// semester 2 features list
const sem2Features = [
  'Guaranteed paid internship upon coursework completion',
  'Real-world AI/ML projects in healthcare analytics and cybersecurity',
  'Industry mentoring and part-time professional experience',
];

const programBenefits = [
  {
    title: '$3000+ Stipend',
  },
  {
    title: 'Guaranteed Internship',
  },
  {
    title: 'Career Workshops',
  },
  {
    title: 'Mentored Projects',
  },
];

// eligibility requirements
const eligibilityReqs = [
  'Enrolled in an undergraduate, associate, or certificate program',
  'Commit to two consecutive semesters of the program',
  'Attend hybrid coursework (Fridays online, Saturdays in-person)',
  'From institutions within 100 to 150 miles of Mississippi State University',
  'No prior ML experience required; Python experience is helpful',
];
---

<Base
  title="Home"
  description="NSF ExLENT XAI Initiative: Experiential Learning in AI/ML Technology at Mississippi State University."
  fullWidth={true}
>
  <!-- full-width hero banner -->
  <section class="bg-gradient-to-br from-maroon-900 via-maroon-800 to-purple-900 text-white w-full">
    <div class="max-w-7xl mx-auto px-6 py-24 text-center">
      <!-- NSF funded badge -->
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-sm font-medium mb-8">
        <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        NSF Funded Program
      </div>
      <h1 class="text-5xl font-extrabold tracking-tight mb-4 leading-tight">
        Experiential Learning in<br />AI/ML Technology
      </h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto mb-3">
        NSF ExLENT XAI Initiative - Mississippi State University
      </p>
      <p class="text-white/65 max-w-2xl mx-auto mb-10 leading-relaxed">
        A National Science Foundation funded program designed for early career undergraduates
        seeking foundational training and hands on experience in Artificial Intelligence and
        Machine Learning.
      </p>
      <!-- primary CTAs -->
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href={withBase('activities/')}
          class="px-6 py-3 bg-white text-maroon-800 rounded-lg font-semibold hover:bg-maroon-50 transition-colors"
        >
          View sessions
        </a>
        <a
          href={withBase('cohorts/')}
          class="px-6 py-3 border border-white/40 text-white rounded-lg font-semibold hover:bg-white/10 transition-colors"
        >
          Meet cohorts
        </a>
        <a
          href={withBase('about/')}
          class="px-6 py-3 border border-white/40 text-white rounded-lg font-semibold hover:bg-white/10 transition-colors"
        >
          Learn more
        </a>
      </div>
    </div>
  </section>

  <!-- program benefit strip -->
  <section class="bg-purple-900 text-white py-8">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {programBenefits.map((benefit) => (
          <div class="rounded-xl border border-white/15 bg-white/10 px-5 py-6 text-center">
            <p class="text-xl font-bold leading-tight">{benefit.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- two-semester program structure -->
  <section class="max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold text-maroon-900 mb-3 text-center">Program Structure</h2>
    <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
      Two consecutive semesters of structured training followed by real world industry experience.
    </p>
    <div class="grid md:grid-cols-2 gap-8">
      <!-- semester 1 card -->
      <div class="rounded-2xl border border-maroon-200 bg-maroon-50 p-8">
        <div class="inline-block bg-maroon-700 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4">
          Semester 1
        </div>
        <h3 class="text-xl font-bold text-maroon-900 mb-2">AI/ML Foundations and Coursework</h3>
        <p class="text-sm text-maroon-700 font-medium mb-5">
          16 weeks | hybrid (Fridays online, Saturdays in-person)
        </p>
        <ul class="space-y-2 mb-6">
          {sem1Features.map((item) => (
            <li class="flex items-start gap-2 text-gray-700 text-sm">
              <svg class="w-4 h-4 text-maroon-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="border-t border-maroon-200 pt-4 space-y-1.5">
          <p class="text-sm text-gray-600"><span class="font-medium text-gray-800">Course stipend:</span> support during the 16 week training sequence</p>
          <p class="text-sm text-gray-600"><span class="font-medium text-gray-800">Format:</span> hybrid Friday and Saturday sessions</p>
        </div>
      </div>

      <!-- semester 2 card -->
      <div class="rounded-2xl border border-purple-200 bg-purple-50 p-8">
        <div class="inline-block bg-purple-700 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4">
          Semester 2
        </div>
        <h3 class="text-xl font-bold text-purple-900 mb-2">Paid AI/ML Industry Internship</h3>
        <p class="text-sm text-purple-700 font-medium mb-5">
          2 to 3 hours per day commitment
        </p>
        <ul class="space-y-2 mb-6">
          {sem2Features.map((item) => (
            <li class="flex items-start gap-2 text-gray-700 text-sm">
              <svg class="w-4 h-4 text-purple-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="border-t border-purple-200 pt-4">
          <p class="text-sm text-gray-600"><span class="font-medium text-gray-800">Guaranteed internship:</span> paid placement after coursework completion</p>
        </div>
      </div>
    </div>
  </section>

  <!-- course schedule timeline -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-maroon-900 mb-2 text-center">Course Schedule</h2>
      <p class="text-gray-600 text-center mb-10 max-w-xl mx-auto">
        Phase 1: Foundations to Deployment (weeks 1-13). Phase 2: Capstone Project (weeks 14-16).
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {courseSchedule.map((entry, i) => (
          <div
            class={`rounded-xl p-5 ${
              i === courseSchedule.length - 1
                ? 'border-2 border-purple-300 bg-purple-50'
                : 'bg-white border border-gray-200'
            }`}
          >
            <span
              class={`text-xs font-bold uppercase tracking-wider ${
                i === courseSchedule.length - 1 ? 'text-purple-600' : 'text-maroon-600'
              }`}
            >
              {entry.weeks.includes('-') ? 'weeks' : 'week'} {entry.weeks}
            </span>
            <p class="text-sm text-gray-700 mt-2 leading-relaxed">{entry.topic}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- current cohort student cards -->
  {currentCohort && currentStudents.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex items-baseline justify-between mb-8 flex-wrap gap-3">
        <div>
          <h2 class="text-3xl font-bold text-maroon-900 mb-1">Cohort {currentCohort.data.year}</h2>
          <p class="text-gray-600 max-w-xl">{currentCohort.data.description}</p>
        </div>
        <a href={withBase('cohorts/')} class="text-sm text-maroon-700 hover:underline font-medium whitespace-nowrap">
          All cohorts
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {currentStudents.map((student) => (
          <div
            class="flex flex-col items-center text-center rounded-2xl border border-gray-200 p-6 bg-white min-h-64"
          >
            {student.data.photo ? (
              <Image
                src={student.data.photo}
                alt={`${student.data.name} photo`}
                width={88}
                height={88}
                class="rounded-full object-cover mb-4 ring-2 ring-maroon-100"
              />
            ) : (
              <div class="w-[88px] h-[88px] rounded-full overflow-hidden mb-4 ring-2 ring-maroon-200">
                <svg viewBox="0 0 72 72" class="w-full h-full" aria-hidden="true">
                  <rect width="72" height="72" fill="#fce7ea"/>
                  <ellipse cx="36" cy="28" rx="12" ry="13" fill="#9a1728"/>
                  <ellipse cx="36" cy="62" rx="23" ry="17" fill="#9a1728"/>
                </svg>
              </div>
            )}
            <p class="text-base font-semibold text-gray-900 mb-1 leading-tight">
              {student.data.name}
            </p>
            {student.data.school && (
              <p class="text-sm text-gray-500 mb-2">{student.data.school}</p>
            )}
            {student.data.major && (
              <span class="text-xs bg-purple-100 text-purple-700 px-2.5 py-1 rounded-full">
                {student.data.major}
              </span>
            )}
            <p class="text-sm text-gray-500 mt-4 leading-relaxed">{student.data.bio}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- recent activities -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center justify-between mb-8 flex-wrap gap-3">
        <h2 class="text-2xl font-bold text-maroon-900">Recent Activities</h2>
        <a href={withBase('activities/')} class="text-sm text-maroon-700 hover:underline font-medium">
          All activities
        </a>
      </div>
      <div class="space-y-5">
        {recentSessions.map((session) => (
          <a
            href={withBase(`activities/${session.id}/`)}
            class="group grid md:grid-cols-[260px_1fr] overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-sm hover:border-maroon-300 hover:shadow-lg transition-all"
          >
            <img
              src={withBase('images/activity/exlent-flyer.jpg')}
              alt=""
              class="h-48 md:h-full w-full object-cover object-top"
              loading="lazy"
            />
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3 flex-wrap">
                <span class="text-xs font-semibold uppercase tracking-wide text-maroon-700 bg-maroon-50 px-2 py-0.5 rounded">
                  {TOPIC_LABELS[session.data.topic] ?? session.data.topic}
                </span>
                <span class="text-xs text-gray-400">
                  Week {session.data.week}
                </span>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 group-hover:text-maroon-700 mb-2">
                {session.data.title}
              </h3>
              <p class="text-sm text-gray-500 line-clamp-3">{session.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- eligibility requirements -->
  <section class="max-w-7xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold text-maroon-900 mb-3 text-center">Eligibility Requirements</h2>
    <p class="text-gray-600 text-center mb-10 max-w-xl mx-auto">
      The program is open to early career students at institutions near Mississippi State University.
    </p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {eligibilityReqs.map((req) => (
        <div class="flex items-start gap-3 p-4 rounded-xl bg-gray-50 border border-gray-200">
          <svg class="w-5 h-5 text-maroon-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <p class="text-sm text-gray-700">{req}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
