---
// custom 404 page shown when a route is not found
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="Page Not Found" description="The requested page could not be found.">
  <div class="text-center py-24">
    <p class="text-8xl font-bold text-gray-100 mb-2" aria-hidden="true">404</p>
    <h1 class="text-2xl font-semibold text-gray-800 mb-3">Page not found</h1>
    <p class="text-gray-600 mb-8">The page you are looking for does not exist or has been moved.</p>
    <a
      href={base}
      class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors"
    >
      Return home
    </a>
  </div>
</Base>
